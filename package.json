{
  "name": "@nu0ma/pr-watcher",
  "version": "0.1.2",
  "description": "Terminal dashboard for monitoring GitHub pull requests",
  "type": "module",
  "bin": {
    "pr-watcher": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "bun run src/cli.tsx",
    "dev": "bun run --watch src/cli.tsx",
    "build": "bun build src/cli.tsx --outdir dist --target node --format esm --packages external",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "github",
    "pull-request",
    "pr",
    "dashboard",
    "cli",
    "terminal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nu0ma/pr-watcher.git"
  },
  "license": "MIT",
  "author": "nu0ma",
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/react": "19.2.14",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "ink": "7.0.0",
    "react": "19.2.5"
  }
}
